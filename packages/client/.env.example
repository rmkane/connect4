# Optional: full WebSocket URL for the game server (otherwise derived from page host + VITE_WS_PORT).
# Use when the client is served from a different origin than the WS API (typical in production).
# VITE_WS_URL=wss://api.example.com

# Port used when VITE_WS_URL is unset (same hostname as the page, this port for ws/wss).
VITE_WS_PORT=3000
